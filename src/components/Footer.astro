---
// Shared site footer.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="foot">
  <div class="container">
    <div class="foot-top">
      <a href={`${base}/`} class="foot-brand" aria-label="Dynasty Volleyball Club — home">
        <img class="foot-logo" src={`${base}/logos/dynasty-crest.png`} alt="Dynasty Volleyball Club" width="400" height="369" />
      </a>
      <div class="cols">
        <div class="col">
          <span class="col-h">Program</span>
          <a href={`${base}/house-league`}>House League</a>
          {/* Coaches page hidden until staff is confirmed — re-add to reconnect. */}
          {/* <a href={`${base}/coaches`}>Coaches</a> */}
          <a href={`${base}/join`}>Join</a>
        </div>
        <div class="col">
          <span class="col-h">Club</span>
          <a href={`${base}/contact`}>Rep Team</a>
          <a href={`${base}/contact`}>Contact</a>
        </div>
        <div class="col">
          <span class="col-h">Contact</span>
          <a href="mailto:dynastyvolleyballcaledon@gmail.com">dynastyvolleyballcaledon@gmail.com</a>
          <a href={`${base}/contact`}>Caledon, Ontario</a>
        </div>
      </div>
    </div>
    <p class="fine mono">© 2026 DYNASTY VOLLEYBALL CLUB &middot; CALEDON, ONTARIO &middot; FIRST SEASON STARTING SOON</p>
  </div>
</footer>

<style>
  .foot { background: var(--wash); padding: 40px 0 26px; }
  .foot-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
  }
  .foot-logo { height: 46px; width: auto; }
  .cols { display: flex; gap: 46px; flex-wrap: wrap; }
  .col-h {
    display: block;
    color: var(--maroon);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 9px;
  }
  .col a { display: block; color: var(--grey); font-size: 13px; text-decoration: none; margin: 5px 0; }
  .col a:hover, .col a:focus-visible { color: var(--gold-deep); }
  .fine { color: var(--grey); font-size: 12px; letter-spacing: 0.04em; margin-top: 16px; }
</style>
