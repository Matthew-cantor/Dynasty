---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dynasty Volleyball Club',
  description = 'A weekly house league in Bolton, Ontario — real coaching, real fundamentals. Ages 8–15. First season starting soon.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const ogImage = Astro.site ? new URL(`${base}/logos/dynasty-crest.png`, Astro.site) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dynasty Volleyball Club" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Expanded:wght@600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
  </body>
</html>
