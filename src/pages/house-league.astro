---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const details = [
  { k: 'Ages', v: '11–16', tbd: false },
  { k: 'Format', v: 'Camp-style training', tbd: false },
  { k: 'Cadence', v: 'Weekly', tbd: false },
  { k: 'Day & time', v: 'Tuesdays 6:30-8', tbd: false },
  { k: 'Location', v: ' Caledon, ON', tbd: false },
  { k: 'Venue', v: 'Mayfield Public School', tbd: false },
  { k: 'Season length', v: '11 weeks, Oct 6th-Dec 15th', tbd: false },
  { k: 'Cost', v: '$275 per Season', tbd: false },
];

const session = [
  { t: 'Warm-up & movement', d: 'Dynamic prep and ball-handling to get bodies ready and touches up early.' },
  { t: 'Skill blocks', d: 'Focused reps on one or two fundamentals — passing, setting, or serving — coached with intent.' },
  { t: 'Small-sided play', d: 'Games that put the day’s skills under real pressure, so learning sticks.' },
  { t: 'Cool-down & recap', d: 'Stretch, reset, and a quick note on what to work on before next week.' },
];

const skills = [
  { t: 'Passing', d: 'Platform, angles, and reading the ball off the serve.' },
  { t: 'Setting', d: 'Hand shape, footwork, and consistent, hittable balls.' },
  { t: 'Serving', d: 'Toss, contact, and serving with purpose and control.' },
  { t: 'Defense', d: 'Ready position, movement, and pursuing every ball.' },
  { t: 'Game Play', d: 'Rotations, communication, and decisions under pressure.' },
];
---

<BaseLayout
  title="House League — Dynasty Volleyball Club"
  description="Dynasty's house league: a weekly, camp-style volleyball training program in Bolton, Ontario for ages 8–15. Fundamentals first, small by design."
>
  <PageHero
    eyebrow="The House League"
    title="Fundamentals first."
    lead="A weekly, camp-style training program in Bolton — not a competitive team. Real coaching, real reps, and a group kept small by design so every player gets attention."
  />

  <!-- DETAILS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">At a glance</p>
        <h2 class="section-title">The program, in plain terms.</h2>
      </div>
      <div class="details">
        {details.map((d) => (
          <div class="detail">
            <span class="k mono">{d.k}</span>
            <span class:list={['v', { tbd: d.tbd }]}>{d.v}</span>
          </div>
        ))}
      </div>
      <p class="details-note">
    </div>
  </section>

  <!-- SESSION FORMAT -->
  <section class="section section--wash">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">A typical session</p>
        <h2 class="section-title">What an session looks like.</h2>
      </div>
      <div class="session">
        <ol class="steps">
          {session.map((s, i) => (
            <li class="step">
              <span class="step-n mono">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="step-t">{s.t}</h3>
                <p class="step-d">{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
        <div class="shot" aria-hidden="true" data-ph="Session photo"></div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we work on</p>
        <h2 class="section-title">Five fundamentals, on repeat.</h2>
      </div>
      <div class="skills">
        {skills.map((s) => (
          <div class="skill">
            <h3 class="skill-t">{s.t}</h3>
            <p class="skill-d">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RATIO CALLOUT -->
  <section class="section section--wash">
    <div class="container callout">
      <p class="eyebrow">Small by design</p>
      <h2 class="section-title">Coaching that reaches every player.</h2>
      <p class="lead callout-lead">
        Groups are kept intentionally small, so coaches actually see each athlete
        — correcting technique in the moment instead of managing a crowd. That’s
        the whole point of the house league: reps that count.
      </p>
    </div>
  </section>

  <CtaBand
    title="Reserve your spot."
    text="No payment today — just tell us you're interested and we'll be in touch about the first season."
    label="Express Interest"
    href={`${base}/join`}
  />
  <Footer />
</BaseLayout>

<style>
  /* details grid */
  .details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .detail {
    padding: 24px 24px 26px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .detail .k {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--grey);
  }
  .detail .v {
    display: block;
    margin-top: 8px;
    font-family: var(--font-disp);
    font-weight: 700;
    font-size: 21px;
    color: var(--maroon);
    line-height: 1.1;
  }
  .detail .v.tbd { color: #9aa0ab; font-weight: 600; font-family: var(--font-body); font-size: 16px; }
  .details-note { color: var(--grey); font-size: 13.5px; margin-top: 20px; text-align: center; }

  /* session */
  .session { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 40px; align-items: start; }
  .steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 22px; }
  .step { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: start; }
  .step-n { color: var(--gold-deep); font-weight: 700; font-size: 14px; padding-top: 3px; }
  .step-t { color: var(--maroon); font-size: 20px; }
  .step-d { color: var(--grey); font-size: 15px; margin: 6px 0 0; }
  .shot {
    height: 100%;
    min-height: 320px;
    border-radius: 22px;
    background:
      radial-gradient(120% 120% at 38% 20%, rgba(201, 162, 39, 0.16), transparent 55%),
      linear-gradient(140deg, #BE2A60, #A1174A 65%, #6E0E32);
    box-shadow: 0 18px 44px rgba(110, 14, 50, 0.2);
    position: relative;
  }
  .shot::after {
    content: attr(data-ph);
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.32);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* skills */
  .skills { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .skill { background: var(--wash); border-radius: 20px; padding: 30px 26px; }
  .skill-t { color: var(--maroon); font-family: var(--font-disp); font-weight: 700; font-size: 22px; }
  .skill-d { color: var(--grey); font-size: 14.5px; margin: 10px 0 0; }

  /* callout */
  .callout { text-align: center; max-width: 680px; margin-inline: auto; }
  .callout-lead { margin: 16px auto 0; }

  @media (max-width: 860px) {
    .details { grid-template-columns: repeat(2, 1fr); }
    .session { grid-template-columns: 1fr; }
    .skills { grid-template-columns: 1fr; }
  }
</style>
